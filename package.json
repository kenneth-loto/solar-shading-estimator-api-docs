{
  "name": "solar-shading-estimator-api-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "devv": "next dev",
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:fix:unsafe": "biome check --write --unsafe",
    "format": "biome format --write",
    "postinstall": "fumadocs-mdx",
    "prepare": "husky || true",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "predev": "bun run scripts/generate-docs.ts",
    "prebuild": "bun run scripts/generate-docs.ts",
    "generate:docs": "bun run scripts/generate-docs.ts",
    "ui": "bun x shadcn@latest add",
    "test": "bun test lib/__tests__/errors.test.ts && bun test lib/__tests__/openapi.test.ts && bun test lib/__tests__/openapi.production.test.ts && bun test scripts/__tests__/generate-docs.test.ts && bun test scripts/__tests__/generate-docs.failure.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@sentry/nextjs": "10",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.10.7",
    "fumadocs-mdx": "15.0.13",
    "fumadocs-openapi": "^11.0.6",
    "fumadocs-ui": "npm:@fumadocs/base-ui@latest",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@sentry/cli"
  ]
}
